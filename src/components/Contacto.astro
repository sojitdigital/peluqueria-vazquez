---
const svgDiamond = `<svg width="8" height="8" viewBox="0 0 8 8" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M4 0L8 4L4 8L0 4Z" fill="#c9a96e" opacity="0.85"/></svg>`;
---

<section id="contacto" class="py-28 bg-dark-800">
  <div class="max-w-5xl mx-auto px-6">
    <div class="md:pl-[2vw] mb-16">
      <p class="text-xs tracking-[0.4em] uppercase text-gold mb-4" data-aos="fade-up">Estamos para vos</p>
      <h2 class="font-heading text-5xl md:text-6xl font-light text-silver-100 mb-4" data-aos="fade-up" data-aos-delay="100">
        Turnos & Consultas
      </h2>
      <div class="ornament" data-aos="fade-up" data-aos-delay="150">
        <Fragment set:html={svgDiamond} />
      </div>
    </div>

    <div class="grid md:grid-cols-2 gap-16 items-start">

      <!-- Formulario → WhatsApp -->
      <div data-aos="fade-right" data-aos-delay="200">
        <h3 class="font-heading text-2xl text-silver-100 font-light mb-1">Envianos tu consulta</h3>
        <p class="text-silver-400 text-xs tracking-widest uppercase mb-8">Completá y te respondemos</p>
        <form id="whatsapp-form" class="space-y-6">
          <div>
            <input type="text" id="nombre" placeholder="Nombre" required
              class="w-full bg-transparent border-b border-dark-600 text-silver-200 py-3 text-sm placeholder-silver-400 focus:outline-none focus:border-gold transition-colors" />
          </div>
          <div>
            <input type="text" id="apellido" placeholder="Apellido" required
              class="w-full bg-transparent border-b border-dark-600 text-silver-200 py-3 text-sm placeholder-silver-400 focus:outline-none focus:border-gold transition-colors" />
          </div>
          <div>
            <textarea id="consulta" placeholder="Tu consulta..." rows="4" required
              class="w-full bg-transparent border-b border-dark-600 text-silver-200 py-3 text-sm placeholder-silver-400 focus:outline-none focus:border-gold transition-colors resize-none"></textarea>
          </div>
          <button type="submit"
            class="btn-slide w-full border border-gold py-4 text-xs tracking-[0.3em] uppercase cursor-pointer">
            <span class="slide-bg"></span>
            <span class="slide-label">Enviar por WhatsApp</span>
          </button>
        </form>
      </div>

      <!-- WhatsApp directo -->
      <div data-aos="fade-left" data-aos-delay="200">
        <h3 class="font-heading text-2xl text-silver-100 font-light mb-1">O escribinos directamente</h3>
        <p class="text-silver-400 text-xs tracking-widest uppercase mb-8">Sin formularios, sin esperas</p>
        <p class="text-silver-400 font-light text-sm mb-10 leading-relaxed">
          Abrí el chat de WhatsApp y escribinos lo que necesitás. Te respondemos a la brevedad.
        </p>
        <a href="https://wa.me/5492994286427" target="_blank" rel="noopener noreferrer"
           class="btn-slide w-full border border-[#25D366] py-4 text-xs tracking-[0.3em] uppercase"
           style="--slide-color: #25D366;">
          <span class="slide-bg" style="background: #25D366;"></span>
          <span class="slide-label flex items-center justify-center gap-3" style="color: #25D366;">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
              <path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.122 1.532 5.855L.057 23.428a.75.75 0 00.921.921l5.573-1.475A11.95 11.95 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.75a9.71 9.71 0 01-4.92-1.334l-.353-.21-3.664.97.983-3.587-.23-.37A9.714 9.714 0 012.25 12C2.25 6.615 6.615 2.25 12 2.25S21.75 6.615 21.75 12 17.385 21.75 12 21.75z"/>
            </svg>
            Abrir WhatsApp
          </span>
        </a>

        <div class="mt-12 pt-10 border-t border-dark-600">
          <p class="text-xs tracking-widest uppercase text-silver-400 mb-4">Encontranos en</p>
          <p class="text-silver-300 font-light text-sm">Hipólito Yrigoyen 220</p>
          <p class="text-silver-400 font-light text-sm">Neuquén Capital</p>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  const form = document.getElementById('whatsapp-form') as HTMLFormElement;
  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const nombre   = (document.getElementById('nombre')   as HTMLInputElement).value.trim();
    const apellido = (document.getElementById('apellido') as HTMLInputElement).value.trim();
    const consulta = (document.getElementById('consulta') as HTMLTextAreaElement).value.trim();
    const msg = `Hola! Mi nombre es ${nombre} ${apellido} y tengo la siguiente consulta: ${consulta}`;
    window.open(`https://wa.me/5492994286427?text=${encodeURIComponent(msg)}`, '_blank');
  });
</script>
