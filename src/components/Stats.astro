    <div class="stat-item border border-transparent px-8 py-6 text-center" data-aos="fade-up" data-aos-delay="300">
      <div class="flex justify-center mb-1">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="#c9a96e" opacity="0.85" aria-hidden="true">
          <path d="M12 2l2.9 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l7.1-1.01L12 2z"/>
        </svg>
      </div>
      <p class="text-xs tracking-widest uppercase text-silver-400">Clientas fidelizadas</p>
    </div>

  </div>
</div>
