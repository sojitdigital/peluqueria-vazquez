---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Vazquez Peluquería — Neuquén' } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Vazquez Peluquería — 30 años de experiencia en Neuquén Capital. Servicios exclusivos para mujeres. Turnos y consultas por WhatsApp." />
    <link rel="icon" type="image/jpeg" href="/images/logo.jpeg" />
    <title>{title}</title>
  </head>
  <body class="bg-dark-900 text-silver-200 font-body antialiased">
    <slot />
  </body>
</html>
