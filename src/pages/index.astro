---
import Layout   from '../layouts/Layout.astro';
import Navbar   from '../components/Navbar.astro';
import Hero     from '../components/Hero.astro';
import Stats    from '../components/Stats.astro';
import Servicios from '../components/Servicios.astro';
import Galeria  from '../components/Galeria.astro';
import Productos from '../components/Productos.astro';
import Contacto from '../components/Contacto.astro';
import Ubicacion from '../components/Ubicacion.astro';
import Footer   from '../components/Footer.astro';
---

<Layout>
  <Navbar />
  <Hero />
  <Stats />
  <Servicios />
  <Galeria />
  <Productos />
  <Contacto />
  <Ubicacion />
  <Footer />
</Layout>

<script>
  import AOS from 'aos';
  import 'aos/dist/aos.css';

  AOS.init({
    duration: 900,
    easing: 'ease-out-quart',
    once: true,
    offset: 60,
  });
</script>
